<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/bg_parchment_pixel">

    <TextView
        android:id="@+id/tvAddEventTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vt323"
        android:text="Nueva Cita"
        android:textColor="#4A2511"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etEventTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_message_pixel"
        android:fontFamily="@font/vt323"
        android:hint="Título de la cita"
        android:padding="12dp"
        android:textColor="#4A2511"
        android:textColorHint="#8B4513"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvAddEventTitle" />

    <EditText
        android:id="@+id/etEventDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_message_pixel"
        android:fontFamily="@font/vt323"
        android:gravity="top"
        android:hint="Descripción (opcional)"
        android:minHeight="80dp"
        android:padding="12dp"
        android:textColor="#4A2511"
        android:textColorHint="#8B4513"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/etEventTitle" />

    <LinearLayout
        android:id="@+id/llTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/etEventDescription">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/vt323"
            android:text="Hora: "
            android:textColor="#4A2511"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnPickTime"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/vt323"
            android:text="Seleccionar"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llRecurrence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/llTime">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/vt323"
            android:text="Repetir: "
            android:textColor="#4A2511"
            android:textSize="18sp" />

        <Spinner
            android:id="@+id/spinnerRecurrence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_pixel"
            android:padding="8dp"
            android:spinnerMode="dropdown"
            android:popupBackground="#F3E5AB"
            android:popupTheme="@style/SpinnerDropdownStyle"
            android:textColor="#4A2511" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/llRecurrence">

        <Button
            android:id="@+id/btnCancelEvent"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/vt323"
            android:text="Cancelar"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8B4513" />

        <View
            android:layout_width="12dp"
            android:layout_height="0dp" />

        <Button
            android:id="@+id/btnSaveEvent"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/vt323"
            android:text="Guardar"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
