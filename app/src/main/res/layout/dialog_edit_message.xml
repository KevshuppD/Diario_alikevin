<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/bg_parchment_pixel">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vt323"
        android:text="Escribir Carta"
        android:textColor="#4A2511"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/formatToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvDialogTitle">

        <Button
            android:id="@+id/btnBold"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B"
            android:textStyle="bold"
            android:fontFamily="@font/vt323"
            android:textSize="18sp"
            android:minWidth="40dp"
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />

        <View android:layout_width="8dp" android:layout_height="0dp"/>

        <Button
            android:id="@+id/btnItalic"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I"
            android:textStyle="italic"
            android:fontFamily="@font/vt323"
            android:textSize="18sp"
            android:minWidth="40dp"
            android:paddingHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />

        <View android:layout_width="8dp" android:layout_height="0dp"/>

        <Button
            android:id="@+id/btnColor"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Color"
            android:fontFamily="@font/vt323"
            android:textSize="16sp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />
    </LinearLayout>

    <EditText
        android:id="@+id/etDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_message_pixel"
        android:fontFamily="@font/vt323"
        android:gravity="top"
        android:hint="Querida Ali..."
        android:inputType="textMultiLine"
        android:minHeight="120dp"
        android:padding="16dp"
        android:textColor="#4A2511"
        android:textColorHint="#8B4513"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/formatToolbar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/imageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/etDialogMessage"
        tools:visibility="visible">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSelectedImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:maxHeight="150dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.SmallComponent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnRemoveImage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FF0000" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlbumPreview"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/imageContainer"
        tools:listitem="@android:layout/simple_list_item_1"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/rvAlbumPreview">

        <Button
            android:id="@+id/btnAddImage"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/vt323"
            android:text="Imagen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />

        <View android:layout_width="8dp" android:layout_height="0dp"/>

        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/vt323"
            android:text="Cancelar"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8B4513" />

        <View android:layout_width="8dp" android:layout_height="0dp"/>

        <Button
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:fontFamily="@font/vt323"
            android:text="Enviar"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D2E7A" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
