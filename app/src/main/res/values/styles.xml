<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PixelText">
        <item name="android:fontFamily">@font/vt323</item>
    </style>

    <style name="Theme.AppCompat.Light.Dialog.Alert.Pixel" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="PixelAlertDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <!-- Personalización básica para el diálogo estilo pixel -->
    </style>

    <style name="SpinnerDropdownStyle" parent="ThemeOverlay.Material3.Light">
        <item name="android:popupBackground">#F3E5AB</item>
        <item name="android:textColor">#4A2511</item>
    </style>

    <style name="PixelButton" parent="Widget.AppCompat.Button">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:backgroundTint">#5D2E7A</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Estilo para CalendarView en Modo Oscuro -->
    <style name="DarkCalendarTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:isLightTheme">false</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#EEEEEE</item>
        <item name="android:textColorPrimaryInverse">#FFFFFF</item>
        <item name="android:colorAccent">#00BCD4</item>
        <item name="android:weekDayTextAppearance">@style/CalendarWhiteText</item>
        <item name="android:dateTextAppearance">@style/CalendarWhiteText</item>
        <item name="android:headerMonthTextAppearance">@style/CalendarWhiteText</item>
    </style>

    <!-- Estilo para CalendarView en Modo Claro -->
    <style name="LightCalendarTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:isLightTheme">true</item>
        <item name="android:textColorPrimary">#4A2511</item>
        <item name="android:textColorSecondary">#8B4513</item>
        <item name="android:textColorPrimaryInverse">#4A2511</item>
        <item name="android:colorAccent">#5D2E7A</item>
        <item name="android:weekDayTextAppearance">@style/CalendarBrownText</item>
        <item name="android:dateTextAppearance">@style/CalendarBrownText</item>
        <item name="android:headerMonthTextAppearance">@style/CalendarBrownText</item>
    </style>

    <style name="CalendarWhiteText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:fontFamily">@font/vt323</item>
    </style>

    <style name="CalendarBrownText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">#4A2511</item>
        <item name="android:textColorPrimary">#4A2511</item>
        <item name="android:fontFamily">@font/vt323</item>
    </style>
</resources>