<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra/Borde exterior pixelado (Gris muy oscuro) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
        </shape>
    </item>

    <!-- Cuerpo del pergamino oscuro (Gris oscuro profundo) -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#2C2C2C" />
        </shape>
    </item>

    <!-- Detalle de esquinas pixeladas -->
    <item android:width="8dp" android:height="8dp" android:gravity="top|left">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="top|right">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|left">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|right">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
</layer-list>