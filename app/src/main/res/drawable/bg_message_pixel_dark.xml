<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Borde exterior (Gris muy oscuro) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
        </shape>
    </item>

    <!-- Cuerpo de burbuja oscura (Gris oscuro profundo) -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#2C2C2C" />
        </shape>
    </item>

    <!-- Esquinas pixeladas -->
    <item android:width="8dp" android:height="8dp" android:gravity="top|left">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="top|right">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|left">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|right">
        <shape><solid android:color="#1A1A1A"/></shape>
    </item>
</layer-list>