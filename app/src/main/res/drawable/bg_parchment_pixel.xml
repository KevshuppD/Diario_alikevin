<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra/Borde exterior pixelado -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#4A2511" />
        </shape>
    </item>

    <!-- Cuerpo del pergamino con margen para el borde -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#F3E5AB" />
        </shape>
    </item>

    <!-- Detalle de "esquinas pixeladas" (simulado con insets) -->
    <item android:width="8dp" android:height="8dp" android:gravity="top|left">
        <shape><solid android:color="#4A2511"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="top|right">
        <shape><solid android:color="#4A2511"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|left">
        <shape><solid android:color="#4A2511"/></shape>
    </item>
    <item android:width="8dp" android:height="8dp" android:gravity="bottom|right">
        <shape><solid android:color="#4A2511"/></shape>
    </item>
</layer-list>